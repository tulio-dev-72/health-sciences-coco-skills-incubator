# Supabase (client-safe publishable values)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Fireblocks (server only — never expose to the browser; see docs/FIREBLOCKS.md)
FIREBLOCKS_API_KEY=
# Vercel/production: inline PEM private key (use \n for line breaks)
FIREBLOCKS_PRIVATE_KEY=
# Local development: path to PEM key file — do not set both PRIVATE_KEY and SECRET_KEY_PATH
FIREBLOCKS_SECRET_KEY_PATH=
FIREBLOCKS_BASE_URL=https://sandbox-api.fireblocks.io/v1

# Optional
# NEXT_PUBLIC_DEMO_MODE=false
# FIREBLOCKS_SOURCE_VAULT_ID=0
# FIREBLOCKS_ASSET_USDC=ETH_TEST5

# Production webhook URL (register in Fireblocks Console):
# https://institutional-workflow-blueprints.vercel.app/api/webhooks/fireblocks
